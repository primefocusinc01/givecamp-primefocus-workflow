rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isDoctor() {
      return isAuthenticated() && getUserRole() == 'doctor';
    }

    function isAdminOrDoctor() {
      return isAdmin() || isDoctor();
    }

    function hasPublicRegistrationShape() {
      return request.resource.data.participant is map
        && request.resource.data.participant.contact is map
        && request.resource.data.participant.contact.email is string
        && request.resource.data.participant.contact.email.size() > 3
        && request.resource.data.participant.contact.email.size() <= 254
        && request.resource.data.participant.firstName is string
        && request.resource.data.participant.firstName.size() > 0
        && request.resource.data.participant.firstName.size() <= 100
        && request.resource.data.participant.lastName is string
        && request.resource.data.participant.lastName.size() > 0
        && request.resource.data.participant.lastName.size() <= 100
        && request.resource.data.participant.consents is map
        && request.resource.data.participant.consents.consentToParticipate == true
        && request.resource.data.participant.consents.communicationAuthorization == true
        && request.resource.data.participant.consents.acknowledgement == true;
    }

    function hasPublicEventShape() {
      return request.resource.data.participantId is string
        && request.resource.data.participantId.size() > 0
        && request.resource.data.participantEmail is string
        && request.resource.data.participantEmail.size() > 3
        && request.resource.data.participantEmail.size() <= 254
        && request.resource.data.eventName is string
        && request.resource.data.eventName.size() > 0
        && request.resource.data.eventName.size() <= 120
        && request.resource.data.eventDate is string
        && request.resource.data.status == 'active';
    }

    function hasPublicStationStatusShape() {
      return request.resource.data.participantId is string
        && request.resource.data.participantId.size() > 0
        && request.resource.data.eventId is string
        && request.resource.data.eventId.size() > 0
        && request.resource.data.id is string
        && request.resource.data.id.size() > 0
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.status in ['pending', 'current', 'complete', 'skipped'];
    }

    match /users/{userId} {
      // New users can create their own profile with the default role only.
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'basic-user';

      // Users can read their own profile; admins can read any profile.
      allow read: if isAuthenticated()
                   && (request.auth.uid == userId || isAdmin());

      // Users can update their own profile but cannot change their role.
      // Admins can update any profile, including roles.
      allow update: if isAuthenticated()
                     && (
                       (request.auth.uid == userId
                        && (!('role' in request.resource.data)
                            || request.resource.data.role == resource.data.role))
                       || isAdmin()
                     );

      // Only admins can delete user profiles.
      allow delete: if isAdmin();
    }

    match /participants/{participantId} {
      // Public registration can create participant records only.
      // Admins and doctors can read and manage participant records.
      allow create: if hasPublicRegistrationShape();
      allow read, update, delete: if isAdminOrDoctor();
    }

    match /events/{eventId} {
      // Public registration can create event records only.
      // Admins and doctors can read and manage event records.
      allow create: if hasPublicEventShape();
      allow read, update, delete: if isAdminOrDoctor();
    }

    match /stationStatuses/{statusId} {
      // Public registration can create initial station statuses only.
      // Admins and doctors can read and manage station status records.
      allow create: if hasPublicStationStatusShape();
      allow read, update, delete: if isAdminOrDoctor();
    }
  }
}
