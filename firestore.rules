rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isDoctor() {
      return isAuthenticated() && getUserRole() == 'doctor';
    }

    function isAdminOrDoctor() {
      return isAdmin() || isDoctor();
    }

    match /users/{userId} {
      // New users can create their own profile with the default role only.
      allow create: if isAuthenticated()
                    && request.auth.uid == userId
                    && request.resource.data.role == 'basic-user';

      // Users can read their own profile; admins can read any profile.
      allow read: if isAuthenticated()
                   && (request.auth.uid == userId || isAdmin());

      // Users can update their own profile but cannot change their role.
      // Admins can update any profile, including roles.
      allow update: if isAuthenticated()
                     && (
                       (request.auth.uid == userId
                        && (!('role' in request.resource.data)
                            || request.resource.data.role == resource.data.role))
                       || isAdmin()
                     );

      // Only admins can delete user profiles.
      allow delete: if isAdmin();
    }

    match /participants/{participantId} {
       // Only admins and doctors can read participant records.
      allow read: if isAdminOrDoctor();
      // Every authenticated user needs to be able to register, so allow writes to /participants.
      allow write: if isAuthenticated();
    }

    match /events/{eventId} {
      // Only admins and doctors can read or write event records.
      allow read, write: if isAdminOrDoctor();
    }

    match /stationStatuses/{statusId} {
      // Only admins and doctors can read or write station status records.
      allow read, write: if isAdminOrDoctor();
    }
  }
}
